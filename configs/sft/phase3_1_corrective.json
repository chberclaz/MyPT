{
  "name": "Phase 3.1: Corrective SFT",
  "description": "Short corrective run for echo/operator/anti-echo + strict JSON behaviors. Intended to continue from phase3_chat_110k_gold.",

  "batch_size": 4,
  "block_size": 4096,
  "vocab_size": 50304,
  "n_embd": 1280,
  "n_head": 20,
  "n_layer": 32,
  "dropout": 0.12,
  "bias": false,
  "tie_weights": true,
  "pos_encoding": "rope",
  "mlp_type": "swiglu",
  "norm_type": "rmsnorm",
  "use_checkpoint": true,
  "rope_theta": 10000.0,
  "rope_scale": 4.0,

  "learning_rate": 1.5e-5,
  "max_iters": 450,
  "eval_interval": 50,
  "save_every": 50,
  "warmup_iters": 60,
  "use_amp": true,
  "amp_dtype": "bf16",
  "grad_accum_steps": 3,

  "use_loss_mask": true,

  "batch_sampling_mode": "epoch",
  "pad_token_id": null,
  "episode_min_tokens": 10,
  "epoch_seed": 3301,
  "epoch_shuffle": true,
  "epoch_drop_last": true,

  "weight_decay": 0.05,

  "eval_sets": {
    "phase1_format": "data/sft_phase1_format_lock",
    "phase2_operators": "data/sft_phase2_operators",
    "phase2_remix_existing": "data/sft_phase3_eval_phase2_remix"
  },
  "eval_seed": 1337,
  "log_file": "logs/train/phase3_1_corrective.jsonl"
}
